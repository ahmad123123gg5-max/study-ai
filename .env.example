PORT=3001
# Frontend origin(s), comma-separated if needed
APP_URL=http://localhost:3000
# Optional explicit frontend origin used for popup messaging and checkout redirects
CLIENT_URL=http://localhost:3000
# Optional public backend origin for OAuth callbacks when API and frontend use different domains
PUBLIC_SERVER_URL=http://localhost:3000
JWT_SECRET=change-me-in-env

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Hybrid AI Architecture
HYBRID_FAST_MODEL=gpt-4o-mini
HYBRID_CACHE_TTL_SECONDS=3600
HYBRID_CACHE_DB_FILE=.tmp/hybrid-cache-db.json
HYBRID_CACHE_NAMESPACE=smartedge:hybrid
HYBRID_RAG_TOP_K=3
HYBRID_VECTOR_DIMENSIONS=256
HYBRID_KNOWLEDGE_DIR=server/knowledge-base
HYBRID_WORKER_CONCURRENCY=2
HYBRID_CLUSTER_WORKERS=1
HYBRID_ALLOW_FILE_STORE_CLUSTERING=false
HYBRID_FULL_AUDIT_LOW_RISK=false
REDIS_URL=
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=smartedge_knowledge

# Stripe
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production example: https://your-service.up.railway.app/auth/google/callback
# Local example: http://localhost:3000/api/auth/oauth/google/callback
GOOGLE_REDIRECT_URI=
# Optional cookie settings for cross-domain deployments
COOKIE_DOMAIN=
# Use `none` when your frontend and backend are on different sites
COOKIE_SAME_SITE=
